<mvc:View
    controllerName="project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:tnt="sap.tnt"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="{i18n>INVENTORY MANAGEMENT SYSTEM }"
    >
        <tnt:ToolHeader
            id="shellLikeToolHeader"
            class="sapUiTinyMargin"
        >
            <Button
                id="_IDGenButton1"
                icon="sap-icon://menu2"
                type="Transparent"
                tooltip="Menu"
                press=".onCollapseExpandPress"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Button>
            <Image
                id="_IDGenImage"
                src="test-resources/sap/tnt/images/SAP_Logo.png"
                decorative="false"
                press="onLogoPressed"
                tooltip="SAP Logo"
                width="60px"
                height="30px"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData1"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Image>
            <Title
                text="Prоduct Name"
                wrapping="false"
                id="productName"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData2"
                        priority="Disappear"
                    />
                </layoutData>
            </Title>
            <Text
                text="Second title"
                wrapping="false"
                id="secondTitle"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData3"
                        priority="Disappear"
                    />
                </layoutData>
            </Text>
            <ToolbarSpacer id="_IDGenToolbarSpacer" />
            <SearchField
                width="25rem"
                id="searchField"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData4"
                        priority="Low"
                        group="1"
                    />
                </layoutData>
            </SearchField>
            <Button
                visible="false"
                icon="sap-icon://search"
                type="Transparent"
                id="searchButton"
                tooltip="Search"
            />
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton"
                icon="sap-icon://da"
                type="Transparent"
                tooltip="Joule"
                text="Joule"
                press="ASKtoai"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData5"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton1"
                icon="sap-icon://source-code"
                type="Transparent"
                tooltip="Action 1"
                text="Action 1"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData6"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton2"
                icon="sap-icon://card"
                type="Transparent"
                tooltip="Action 2"
                text="Action 2"
                press="onAskai"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData7"
                        group="2"
                    />
                </layoutData>
            </OverflowToolbarButton>
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton3"
                icon="sap-icon://action-settings"
                type="Transparent"
                text="Settings"
            />
            <Button
                id="_IDGenButton2"
                icon="sap-icon://bell"
                type="Transparent"
                tooltip="Notification"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData8"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Button>
            <tnt:ToolHeaderUtilitySeparator
                id="_IDGenToolHeaderUtilitySeparator"
            />
            <OverflowToolbarButton
                id="_IDGenOverflowToolbarButton4"
                icon="sap-icon://grid"
                type="Transparent"
                text="My Products"
                tooltip="My Products"
            />
            <Avatar
                id="_IDGenAvatar"
                src="test-resources/sap/tnt/images/"
                displaySize="XS"
                press=".onAvatarPressed"
                tooltip="Profile"
            >
                <layoutData>
                    <OverflowToolbarLayoutData
                        id="_IDGenOverflowToolbarLayoutData9"
                        priority="NeverOverflow"
                    />
                </layoutData>
            </Avatar>
        </tnt:ToolHeader>
        <!-- side navigation -->
        <HBox id="_IDGenHBox1">
            <VBox id="_IDGenVBox">
                <tnt:SideNavigation
                    id="sideNavigation"
                    selectedKey="walked"
                    expanded="true"
                >
                    <tnt:NavigationList id="_IDGenNavigationList1">
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem"
                            text="View Products"
                            icon="sap-icon://home"
                            press="onViewProducts"
                        />
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup"
                            text="New"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem1"
                                text="view product"
                                icon="sap-icon://people-connected"
                                press="onPressVisible"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem2"
                                text="List of ordered products "
                                icon="sap-icon://building"
                                
                                press="onPressListProducts"
                            >
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem3"
                                    text=""
                                />
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem4"
                                    text=""
                                />
                            </tnt:NavigationListItem>
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem5"
                                text=""
                                icon="sap-icon://mileage"
                            >
                                <tnt:NavigationListItem
                                    id="_IDGenNavigationListItem6"
                                    text="Driven"
                                />
                                <tnt:NavigationListItem
                                    text="Walked"
                                    id="walked"
                                />
                            </tnt:NavigationListItem>
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup1"
                            text="Recently used"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem7"
                                text="Managing My Area"
                                icon="sap-icon://kpi-managing-my-area"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem8"
                                text="Flight"
                                icon="sap-icon://flight"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem9"
                                text="Map"
                                icon="sap-icon://map-2"
                            />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListGroup
                            id="_IDGenNavigationListGroup2"
                            text="Restricted"
                            enabled="false"
                        >
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem10"
                                text="Running"
                                icon="sap-icon://physical-activity"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem11"
                                text="Scissors"
                                icon="sap-icon://scissors"
                            />
                        </tnt:NavigationListGroup>
                        <tnt:NavigationListItem
                            id="_IDGenNavigationListItem12"
                            text="Transport"
                            icon="sap-icon://passenger-train"
                        />
                    </tnt:NavigationList>
                    <tnt:fixedItem>
                        <tnt:NavigationList id="_IDGenNavigationList2">
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem13"
                                text="Bar Chart"
                                icon="sap-icon://bar-chart"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem14"
                                selectable="false"
                                href="https://sap.com"
                                target="_blank"
                                text="External Link"
                                icon="sap-icon://attachment"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem15"
                                selectable="false"
                                href="https://sap.com"
                                target="_top"
                                text="External Link _top"
                                icon="sap-icon://attachment"
                            />
                            <tnt:NavigationListItem
                                id="_IDGenNavigationListItem16"
                                text="Compare"
                                icon="sap-icon://compare"
                            />
                        </tnt:NavigationList>
                    </tnt:fixedItem>
                </tnt:SideNavigation>
            </VBox>
            <VBox id="_IDGenVBox1">
                <Panel
                    id="_IDGenPanel1"
                    width="auto"
                    class="sapUiResponsiveMargin"
                    accessibleRole="Region"
                    visible="true"
                >
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar">
                            <Title
                                id="_IDGenTitle"
                                text="product details"
                            />
                        </OverflowToolbar>
                    </headerToolbar>

                    <!-- table view  -->
                    <Table
                        id="inventoryTable"
                        items="{/products}"
                    >
                        <columns>
                            <Column id="_IDGenColumn">
                                <Text
                                    id="_IDGenText"
                                    text="productName "
                                />
                            </Column>

                            <Column id="_IDGenColumn2">
                                <Text
                                    id="_IDGenText1"
                                    text="description"
                                />
                            </Column>

                            <Column id="_IDGenColumn3">
                                <Text
                                    id="_IDGenText2"
                                    text="price "
                                />
                            </Column>

                            <Column id="_IDGenColumn4">
                                <Text
                                    id="_IDGenText3"
                                    text="stock "
                                />
                            </Column>

                            <Column id="_IDGenColumn6" />
                        </columns>

                        <items>
                            <ColumnListItem id="_IDGenColumnListItem">
                                <cells>
                                    <Text
                                        id="_IDGenText5"
                                        text="{name}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText6"
                                        text="{description}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText7"
                                        text="{price}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText8"
                                        text="{stock}"
                                    />
                                </cells>
                                <cells>
                                    <Button
                                        id="_IDGenButton3"
                                        text="Order"
                                        type="Accept"
                                        press="onRegisterPress"
                                    />
                                    <Button
                                        id="_IDGenButton"
                                        text="Register"
                                        press="onRegisterPress"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>

                    <Dialog
                        id="orderDialog"
                        title="Order Details"
                    >
                        <content>
                            <VBox
                                id="_IDGenVBox2"
                                class="sapUiSmallMargin"
                            >
                                <Label
                                    id="_IDGenLabel"
                                    text="Quantity"
                                />
                                <Input
                                    id="_IDGenInput1"
                                    placeholder="Enter quantity"
                                />

                                <Label
                                    id="_IDGenLabel1"
                                    text="Status"
                                />
                                <Input
                                    id="_IDGenInput"
                                    placeholder="Enter status"
                                />
                            </VBox>
                        </content>

                        <beginButton>
                            <Button
                                id="_IDGenButton4"
                                text="Submit"
                                press="onSubmitOrder"
                            />
                        </beginButton>

                        <endButton>
                            <Button
                                id="_IDGenButton5"
                                text="Cancel"
                                press="onCloseDialog"
                            />
                        </endButton>
                    </Dialog>
                    <Dialog
                        id="askAIdialog"
                        title="ASK TO AI"
                    >
                        <content>
                            <VBox
                                id="_IDGenVBox3"
                                class="sapUiSmallMargin"
                            >
                                <Label
                                    id="_IDGenLabel2"
                                    text="Query"
                                />
                                <Input
                                    id="_IDGenInput2"
                                    placeholder="Enter your query "
                                />
                            </VBox>
                        </content>

                        <beginButton>
                            <Button
                                id="_IDGenButton6"
                                text="Submit"
                                press="onsubmitAI"
                            />
                        </beginButton>

                        <endButton>
                            <Button
                                id="_IDGenButton7"
                                text="close"
                                press="oncloseAI"
                            />
                        </endButton>
                    </Dialog>
                </Panel>

                <Panel
                    id="_IDGenPanel2"
                    width="auto"
                    class="sapUiResponsiveMargin"
                    accessibleRole="Region"
                    visible="false"
                >
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar1">
                            <Title
                                id="_IDGenTitle1"
                                text="List of details"
                            />
                        </OverflowToolbar>
                    </headerToolbar>

                    <Table
                        id="_IDGenTable"
                        items="{aiProductModel>/}"
                        visible="true"
                    >
                        <columns>
                            <Column id="_IDGenColumn1">
                                <Text
                                    id="_IDGenText9"
                                    text="productName "
                                />
                            </Column>

                            <Column id="_IDGenColumn5">
                                <Text
                                    id="_IDGenText10"
                                    text="description"
                                />
                            </Column>

                            <Column id="_IDGenColumn7">
                                <Text
                                    id="_IDGenText11"
                                    text="price "
                                />
                            </Column>

                            <Column id="_IDGenColumn8">
                                <Text
                                    id="_IDGenText12"
                                    text="stock "
                                />
                            </Column>

                            <Column id="_IDGenColumn9" />
                        </columns>

                        <items>
                            <ColumnListItem id="_IDGenColumnListItem1">
                                <cells>
                                    <Text
                                        id="_IDGenText13"
                                        text="{aiProductModel>name}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText14"
                                        text="{aiProductModel>description}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText15"
                                        text="{aiProductModel>price}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText16"
                                        text="{aiProductModel>stock}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>

                <Panel
                    id="_IDGenPanel"
                    width="auto"
                    class="sapUiResponsiveMargin"
                    accessibleRole="Region"
                    visible="false"
                >
                    <headerToolbar>
                        <OverflowToolbar id="_IDGenOverflowToolbar2">
                            <Title
                                id="_IDGenTitle3"
                                text="List of details"
                            />
                        </OverflowToolbar>
                    </headerToolbar>

                    <Table
                        id="_IDGenTable1"
                        items="{path:'/orders', parameters:{ $expand:'product'}}"
                    >
                        <columns>
                            <Column id="_IDGenColumn10">
                                <Text
                                    id="_IDGenText17"
                                    text="productName"
                                />
                            </Column>

                            <Column id="_IDGenColumn11">
                                <Text
                                    id="_IDGenText18"
                                    text="quantity"
                                />
                            </Column>

                            <Column id="_IDGenColumn12">
                                <Text
                                    id="_IDGenText19"
                                    text="status"
                                />
                            </Column>

                            <Column id="_IDGenColumn13">
                                <Text
                                    id="_IDGenText20"
                                    text="createAt"
                                />
                            </Column>

                            <Column id="_IDGenColumn14" />
                        </columns>

                        <items>
                            <ColumnListItem id="_IDGenColumnListItem2">
                                <cells>
                                    <Text
                                        id="_IDGenText21"
                                        text="{product/name}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText22"
                                        text="{quantity}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText23"
                                        text="{status}"
                                    />
                                </cells>

                                <cells>
                                    <Text
                                        id="_IDGenText24"
                                        text="{createAt}"
                                    />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </Panel>
            </VBox>
        </HBox>
    </Page>
</mvc:View>
